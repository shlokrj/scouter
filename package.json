{
  "name": "scouter",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "dev:cloudflare": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build:cloudflare": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start:cloudflare": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "db:generate": "drizzle-kit generate",
    "test": "npm run build:cloudflare && node --import tsx --test tests/**/*.test.*",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "^0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
